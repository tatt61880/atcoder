func main()
	var n: int :: cui@inputInt()
	
	var sum: int :: 0
	var w: []int :: #[n]int
	for i(0, n - 1)
		do w[i] :: cui@inputInt()
		do sum :+ w[i]
	end for
	
	var ans: int :: lib@intMax
	
	var s1: int :: 0
	for i(0, n - 1)
		do s1 :+ w[i]
		var s2: int :: sum - s1
		do ans :: lib@min(ans, (s1 - s2).abs())
	end for
	
	do cui@print("\{ans}\n")
end func
