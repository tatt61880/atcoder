func main()
	var n: int :: cui@inputInt()
	var d: int :: cui@inputInt()
	
	var x: [][]int :: #[n, d]int
	for i(0, n - 1)
		for j(0, d - 1)
			do x[i][j] :: cui@inputInt()
		end for
	end for
	
	var ans: int :: 0
	
	for i(0, n - 2)
		for j(i + 1, n - 1)
			var sum: int :: 0
			for k(0, d - 1)
				do sum :+ (x[i][k] - x[j][k]) ^ 2
			end for
			var a: int :: ((sum $ float - 0.1) ^ 0.5) $ int + 1
			if(a ^ 2 = sum)
				do ans :+ 1
			end if
		end for
	end for
	
	do cui@print("\{ans}\n")
end func
