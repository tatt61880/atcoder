func main()
	var n: int :: cui@inputInt()
	var m: int :: cui@inputInt()
	
	var a: []int :: #[n]int
	for i(0, n - 1)
		do a[i] :: cui@inputInt()
	end for
	
	var b: []int :: #[m]int
	for i(0, m - 1)
		do b[i] :: cui@inputInt()
	end for
	
	do a.sort()
	do b.sort()
	
	var ans: []int :: #[0]int
	
	for i(0, n - 1)
		for j(0, m - 1)
			if(a[i] = b[j])
				do ans :~ [a[i]]
				skip i
			end if
		end for
	end for
	
	do cui@print("\{ans.join(" ")}\n")
end func