func main()
	var n: int :: cui@inputInt()
	var m: int :: cui@inputInt()
	
	var nums: []int :: #[m + 1]int
	
	for(1, n)
		var k: int :: cui@inputInt()
		for(1, k)
			var a: int :: cui@inputInt()
			do nums[a] :+ 1
		end for
	end for
	
	var ans: int :: 0
	for i(1, m)
		do ans :+ nums[i] = n ?(1, 0)
	end for
	
	do cui@print("\{ans}\n")
end func
