func main()
 var h:int::cui@inputInt()
 var w:int::cui@inputInt()
 var q:int::cui@inputInt()
 for(1,q)
  if(cui@inputInt()=1)
   var n:int::cui@inputInt()
   var ans:int::w*n
   do h:-n
   do cui@print("\{ans}\n")
  else
   var n:int::cui@inputInt()
   var ans:int::h*n
   do w:-n
   do cui@print("\{ans}\n")
  end if
 end for
end func