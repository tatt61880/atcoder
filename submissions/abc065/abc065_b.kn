func main()
	var n: int :: cui@inputInt()
	var a: []int :: #[n + 1]int
	for i(1, n)
		do a[i] :: cui@inputInt()
	end for
	
	var idx: int :: 1
	var ans: int :: 0
	
	while loop(true)
		do ans :+ 1
		var next: int :: a[idx]
		do a[idx] :: 0
		do idx :: next
		
		if(next = 0)
			do ans :: -1
			break loop
		elif(next = 2)
			break loop
		end if
	end while
	
	do cui@print("\{ans}\n")
end func
