func main()
	var n: int :: cui@inputInt()
	var d: int :: cui@inputInt()
	
	var t: []int :: #[n]int
	var l: []int :: #[n]int
	for i(0, n - 1)
		do t[i] :: cui@inputInt()
		do l[i] :: cui@inputInt()
	end for
	
	for k(1, d)
		var a: []int :: #[n]int
		for i(0, n - 1)
			do a[i] :: t[i] * (k + l[i])
		end for
		var ans: int :: a.max()
		do cui@print("\{ans}\n")
	end for
end func
