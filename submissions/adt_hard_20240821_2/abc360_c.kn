func main()
	var n: int :: cui@inputInt()
	
	var a: []int :: #[n]int
	for i(0, n - 1)
		do a[i] :: cui@inputInt()
	end for
	
	var w: []int :: #[n]int
	for i(0, n - 1)
		do w[i] :: cui@inputInt()
	end for
	
	var ans: int :: 0
	var b: []int :: #[n]int
	for i(0, n - 1)
		do b[a[i] - 1] :: lib@max(b[a[i] - 1], w[i])
		do ans :+ w[i]
	end for
	
	for i(0, n - 1)
		do ans :- b[i]
	end for
	
	do cui@print("\{ans}\n")
end func
