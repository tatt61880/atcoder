func main()
	var n: int :: cui@inputInt()
	var a: []int :: #[n]int
	for i(0, n - 1)
		do a[i] :: cui@inputInt()
	end for
	
	var ans: int :: 0
	while(true)
		do a.sort()
		do a.reverse()
		if(a[1] <= 0)
			do cui@print("\{ans}\n")
			ret
		end if
		do ans :+ 1
		do a[0] :- 1
		do a[1] :- 1
	end while
end func
