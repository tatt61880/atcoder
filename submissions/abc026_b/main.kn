func main()
	var n: int :: cui@inputInt()
	
	var r: []int :: #[n]int
	for i(0, n - 1)
		do r[i] :: cui@inputInt()
	end for
	
	do r.sort()
	do r.reverse()
	
	var ans: float :: 0.0
	
	for i(0, n - 1)
		if(i % 2 = 0)
			do ans :+ lib@pi * (r[i] ^ 2) $ float
		else
			do ans :- lib@pi * (r[i] ^ 2) $ float
		end if
	end for
	
	do cui@print("\{ans}\n")
end func
