func main()
	var n: int :: cui@inputInt()
	var m: int :: cui@inputInt()
	var s: [][]char :: #[n][]char
	for i(0, n - 1)
		do s[i] :: cui@input()
	end for
	var t: [][]char :: #[m][]char
	for i(0, m - 1)
		do t[i] :: cui@input()
	end for
	
	var ans: int :: 0
	
	for i(0, n - 1)
		for j(0, m - 1)
			if(s[i].sub(^s[i] - 3, 3) = t[j])
				do ans :+ 1
				skip i
			end if
		end for
	end for
	
	do cui@print("\{ans}\n")
end func
