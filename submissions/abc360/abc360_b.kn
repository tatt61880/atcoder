func main()
	var s: []char :: cui@inputStr()
	var t: []char :: cui@inputStr()
	
	var n: int :: ^s
	var ans: bool :: false
	for w(1, n - 1)
		for c(1, w)
			var x: []char :: ""
			
			var i: int :: c
			while(i <= n)
				do x :~ [s[i - 1]]
				do i :+ w
			end while
			
			if(x = t)
				do ans :: true
				break w
			end if
		end for
	end for
	
	do cui@print((ans ?("Yes", "No")) ~ "\n")
end func
