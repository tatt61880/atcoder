func main()
	var n: int :: cui@inputInt()
	var v: []int :: #[n]int
	for i(0, n - 1)
		do v[i] :: cui@inputInt()
	end for
	var c: []int :: #[n]int
	for i(0, n - 1)
		do c[i] :: cui@inputInt()
	end for
	
	var ans: int :: 0
	for i(0, n - 1)
		do ans :+ lib@max(0, v[i] - c[i])
	end for
	
	do cui@print("\{ans}\n")
end func
