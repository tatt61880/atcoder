func main()
	var n: int :: cui@inputInt()
	var l: []int :: #[n]int
	for i(0, n - 1)
		do l[i] :: cui@inputInt()
	end for
	
	var ans: int :: 0
	
	for i(0, n - 1)
		var a: int :: l[i]
		for j(i + 1, n - 1)
			var b: int :: l[j]
			for k(j + 1, n - 1)
				var c: int :: l[k]
				if(a = b | b = c | c = a)
					skip k
				end if
				if(a + b > c & b + c > a & c + a > b)
					do ans :+ 1
				end if
			end for
		end for
	end for
	
	do cui@print("\{ans}\n")
end func
