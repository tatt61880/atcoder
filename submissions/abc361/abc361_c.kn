func main()
	var n: int :: cui@inputInt()
	var k: int :: cui@inputInt()
	var a: []int :: #[n]int
	for i(0, n - 1)
		do a[i] :: cui@inputInt()
	end for
	do a.sort()
	
	var ans: int :: lib@intMax
	
	for i(0, k)
		do ans :: lib@min(ans, a[i + n - 1 - k] - a[i])
	end for
	
	do cui@print("\{ans}\n")
end func
