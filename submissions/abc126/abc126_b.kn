func main()
	var s: []char :: cui@input()
	var a: int :: s.sub(0, 2).toInt(&)
	var b: int :: s.sub(2, 2).toInt(&)
	var am: bool :: 1 <= a & a <= 12
	var bm: bool :: 1 <= b & b <= 12
	switch((am ?(1, 0)) + (bm ?(2, 0)))
	case 0
		do cui@print("NA\n")
	case 1
		do cui@print("MMYY\n")
	case 2
		do cui@print("YYMM\n")
	case 3
		do cui@print("AMBIGUOUS\n")
	end switch
end func
