func main()
	var n: int :: cui@inputInt()
	var m: int :: cui@inputInt()
	
	var s: [][]char :: #[n][]char
	for i(0, n - 1)
		do s[i] :: cui@input()
	end for
	
	var ans: int :: 0
	
	for i(0, n - 1)
		for j(i + 1, n - 1)
			for k(0, m - 1)
				if(s[i][k] = 'x' & s[j][k] = 'x')
					skip j
				end if
			end for
			do ans :+ 1
		end for
	end for
	
	do cui@print("\{ans}\n")
end func
