func main()
	var n: int :: cui@inputInt()
	var k: int :: cui@inputInt()
	
	var a: []int :: #[n]int
	for i(0, n - 1)
		do a[i] :: cui@inputInt()
	end for
	
	do a.sort()
	
	var ans: float :: 0.0
	
	for i(n - k, n - 1)
		do ans :: (ans + a[i] $ float) $ float * 0.5
	end for
	
	do cui@print("\{ans}\n")
end func
