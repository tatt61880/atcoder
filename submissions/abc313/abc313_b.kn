func main()
	var n: int :: cui@inputInt()
	var x: []int :: #[n + 1]int
	for i(1, n)
		do x[i] :: i
	end for
	
	var m: int :: cui@inputInt()
	for i(1, m)
		var a: int :: cui@inputInt()
		var b: int :: cui@inputInt()
		do x[b] :: 0
	end for
	
	var sum: int :: 0
	for i(1, n)
		do sum :+ x[i]
	end for
	
	var ans: int :: sum
	
	if(sum > n | x[sum] <> sum)
		do ans :: -1
	end if
	
	do cui@print("\{ans}\n")
end func
