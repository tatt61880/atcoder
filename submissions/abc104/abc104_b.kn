func main()
	var s: []char :: cui@input()
	
	var ans: bool :: true
	var cCnt: int :: 0
	
	for i(2, ^s - 2)
		if(cCnt = 0 & s[i] = 'C')
			do cCnt :+ 1
		elif(s[i] < 'a')
			do ans :: false
			break i
		end if
	end for
	
	do ans :: ans & s[0] = 'A' & s[1] >= 'a' & s[^s - 1] >= 'a' & cCnt = 1
	do cui@print((ans ?("AC", "WA")) ~ "\n")
end func
