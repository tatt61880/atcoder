func main()
	var n: int :: cui@inputInt()
	var s: [][]char :: #[n][]char
	var max: int :: 0
	for i(0, n - 1)
		do s[i] :: cui@input()
		do max :: lib@max(max, ^s[i])
	end for
	
	for i(0, n - 1)
		var k: int :: (max - ^s[i]) / 2
		do cui@print(".".repeat(k) ~ s[i] ~ ".".repeat(k) ~ "\n")
	end for
end func
