func main()
	const n: int :: 8
	var s: [][]char :: #[n][]char
	for i(0, n - 1)
		do s[i] :: cui@input()
	end for
	
	var rows: dict<int, bool> :: #dict<int, bool>
	var cols: dict<int, bool> :: #dict<int, bool>
	for i(0, n - 1)
		for j(0, n - 1)
			if(s[i][j] = '#')
				do rows.add(i, true)
				do cols.add(j, true)
			end if
		end for
	end for
	
	var ans: int :: (n - ^rows) * (n - ^cols)
	do cui@print("\{ans}\n")
end func
