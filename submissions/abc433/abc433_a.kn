func main()
	var x: int :: cui@inputInt()
	var y: int :: cui@inputInt()
	var z: int :: cui@inputInt()
	
	var ans: bool :: false
	
	while loop(x >= y * z)
		if(x = y * z)
			do ans :: true
			break loop
		end if
		do x :+ 1
		do y :+ 1
	end while
	
	do cui@print((ans ?("Yes", "No")) ~ "\n")
end func
