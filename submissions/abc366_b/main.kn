func main()
	var n: int :: cui@inputInt()
	var s: [][]char :: #[n][]char
	var max: int :: 0
	for i(0, n - 1)
		do s[i] :: cui@input()
		if(^s[i] < max)
			do s[i] :~ "*".repeat(max - ^s[i])
		end if
		do max :: lib@max(max, ^s[i])
	end for
	
	for i(0, max - 1)
		var ans: []char :: #[0]char
		for j(n - 1, 0, -1)
			if(i >= ^s[j])
				break j
			end if
			do ans :~ [s[j][i]]
		end for
		do cui@print("\{ans}\n")
	end for
end func
