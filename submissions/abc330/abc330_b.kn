func main()
	var n: int :: cui@inputInt()
	var l: int :: cui@inputInt()
	var r: int :: cui@inputInt()
	
	var a: []int :: #[n]int
	for i(0, n - 1)
		do a[i] :: cui@inputInt()
		if(a[i] < l)
			do a[i] :: l
		elif(a[i] > r)
			do a[i] :: r
		end if
	end for
	
	do cui@print("\{a.join(" ")}\n")
end func
