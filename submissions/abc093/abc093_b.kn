func main()
	var a: int :: cui@inputInt()
	var b: int :: cui@inputInt()
	var k: int :: cui@inputInt()
	
	if(b - a + 1 > 2 * k)
		for i(a, a + k - 1)
			do cui@print("\{i}\n")
		end for
		for i(b - k + 1, b)
			do cui@print("\{i}\n")
		end for
	else
		for i(a, b)
			do cui@print("\{i}\n")
		end for
	end if
end func
