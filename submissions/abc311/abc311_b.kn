func main()
	var n: int :: cui@inputInt()
	var d: int :: cui@inputInt()
	var s: [][]char :: #[n][]char
	for i(0, n - 1)
		do s[i] :: cui@input()
	end for
	
	var num: int :: 0
	var ans: int :: 0
	
	for j(0, d - 1)
		for i(0, n - 1)
			if(s[i][j] <> 'o')
				do num :: 0
				skip j
			end if
		end for
		
		do num :+ 1
		do ans :: lib@max(ans, num)
	end for
	
	do cui@print("\{ans}\n")
end func
