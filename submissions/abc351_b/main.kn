func main()
	var n: int :: cui@inputInt()
	var a: [][]char :: #[n][]char
	for i(0, n - 1)
		do a[i] :: cui@input()
	end for
	
	var b: [][]char :: #[n][]char
	for i(0, n - 1)
		do b[i] :: cui@input()
	end for
	
	for i(0, n - 1)
		for j(0, n - 1)
			if(a[i][j] <> b[i][j])
				do cui@print("\{i + 1} \{j + 1}\n")
				ret
			end if
		end for
	end for
end func
