func main()
	var n: int :: cui@inputInt()
	var l: int :: 0
	var r: int :: 0
	
	var ans: int :: 0
	
	for(1, n)
		var a: int :: cui@inputInt()
		var c: char :: cui@inputChar()
		if(c = 'L')
			if(l = 0)
				do l :: a
			end if
			
			do ans :+ (a - l).abs()
			do l :: a
		else
			if(r = 0)
				do r :: a
			end if
			
			do ans :+ (a - r).abs()
			do r :: a
		end if
	end for
	
	do cui@print("\{ans}\n")
end func
