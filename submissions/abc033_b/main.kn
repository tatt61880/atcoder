func main()
	var n: int :: cui@inputInt()
	var s: [][]char :: #[n][]char
	var p: []int :: #[n]int
	var sum: int :: 0
	for i(0, n - 1)
		do s[i] :: cui@inputStr()
		do p[i] :: cui@inputInt()
		do sum :+ p[i]
	end for
	
	for i(0, n - 1)
		if(p[i] * 2 > sum)
			do cui@print("\{s[i]}\n")
			ret
		end if
	end for
	
	do cui@print("atcoder\n")
end func
