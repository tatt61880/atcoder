func main()
	var n: int :: cui@inputInt()
	var s: int :: cui@inputInt()
	var m: int :: cui@inputInt()
	var l: int :: cui@inputInt()
	
	var ans: int :: lib@intMax
	for i(0, n)
		for j(0, n)
			for k(0, n)
				var x: int :: i * 6 + j * 8 + k * 12
				if(x >= n)
					var v: int :: i * s + j * m + k * l
					do ans :: lib@min(ans, v)
					break k
				end if
			end for
		end for
	end for
	
	do cui@print("\{ans}\n")
end func
