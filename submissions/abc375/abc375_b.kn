func main()
	var n: int :: cui@inputInt()
	
	var x: []int :: #[n + 2]int
	var y: []int :: #[n + 2]int
	do x[0] :: 0
	do y[0] :: 0
	for i(1, n)
		do x[i] :: cui@inputInt()
		do y[i] :: cui@inputInt()
	end for
	
	var ans: float :: 0.0
	for i(1, n + 1)
		do ans :+ (((x[i] - x[i - 1]) ^ 2) + ((y[i] - y[i - 1]) ^ 2)) $ float ^ 0.5
	end for
	do cui@print("\{ans}\n")
end func
