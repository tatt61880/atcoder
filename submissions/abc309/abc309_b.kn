func main()
	var n: int :: cui@inputInt()
	
	var s: [][]char :: #[n][]char
	for i(0, n - 1)
		do s[i] :: cui@input()
	end for
	
	var t: char :: s[0][0]
	for i(0, n - 2)
		do s[i][0] :: s[i + 1][0]
	end for
	for i(0, n - 2)
		do s[n - 1][i] :: s[n - 1][i + 1]
	end for
	for i(n - 1, 1, -1)
		do s[i][n - 1] :: s[i - 1][n - 1]
	end for
	for i(n - 1, 2, -1)
		do s[0][i] :: s[0][i - 1]
	end for
	do s[0][1] :: t
	
	do cui@print("\{s.join("\n")}\n")
end func
