func main()
	var n: int :: cui@inputInt()
	var m: int :: cui@inputInt()
	var a: []int :: #[m]int
	for i(0, m - 1)
		do a[i] :: cui@inputInt()
	end for
	
	for(1, n)
		for i(0, m - 1)
			do a[i] :- cui@inputInt()
		end for
	end for
	
	var ans: bool :: a.max() <= 0
	do cui@print((ans ?("Yes", "No")) ~ "\n")
end func
