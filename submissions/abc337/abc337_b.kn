func main()
	var s: []char :: cui@inputStr()
	
	var idx: int :: 0
	while(idx <> ^s & s[idx] = 'A')
		do idx :+ 1
	end while
	while(idx <> ^s & s[idx] = 'B')
		do idx :+ 1
	end while
	while(idx <> ^s & s[idx] = 'C')
		do idx :+ 1
	end while
	
	var ans: bool :: idx = ^s
	do cui@print((ans ?("Yes", "No")) ~ "\n")
end func
