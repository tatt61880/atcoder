func main()
	var n: int :: cui@inputInt()
	var d: int :: cui@inputInt()
	var x: int :: cui@inputInt()
	var a: []int :: #[n]int
	for i(0, n - 1)
		do a[i] :: cui@inputInt()
	end for
	
	var cnt: int :: x
	
	for i(0, d - 1)
		for j(0, n - 1)
			if(i % a[j] = 0)
				do cnt :+ 1
			end if
		end for
	end for
	
	var ans: int :: cnt
	do cui@print("\{ans}\n")
end func
