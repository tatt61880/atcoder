func main()
	var n: int :: cui@inputInt()
	var m: int :: cui@inputInt()
	
	var nums: []int :: #[n + 1]int
	
	for(1, m)
		var a: int :: cui@inputInt()
		var b: int :: cui@inputInt()
		do nums[a] :+ 1
		do nums[b] :+ 1
	end for
	
	for i(1, n)
		var ans: int :: nums[i]
		do cui@print("\{ans}\n")
	end for
end func
