func main()
	var n: int :: cui@inputInt()
	var l: int :: cui@inputInt()
	var q: int :: cui@inputInt()
	
	var s: [][]char :: #[n][]char
	for i(0, n - 1)
		do s[i] :: cui@input()
	end for
	
	for(1, q)
		var ans: []char :: "0".repeat(l)
		
		var m: int :: cui@inputInt()
		for(1, m)
			var c: int :: cui@inputInt()
			for i(0, l - 1)
				if(s[c - 1][i] = '1')
					do ans[i] :: '1'
				end if
			end for
		end for
		
		do cui@print("\{ans}\n")
	end for
end func
