func main()
	var n: int :: cui@inputInt()
	var p: []int :: #[n]int
	for i(0, n - 1)
		do p[i] :: cui@inputInt()
	end for
	
	var ans: int :: 0
	
	for i(0, n - 3)
		if(p[i] < p[i + 1] & p[i + 1] < p[i + 2]
			||p[i] > p[i + 1] & p[i + 1] > p[i + 2])
			do ans :+ 1
		end if
	end for
	
	do cui@print("\{ans}\n")
end func
