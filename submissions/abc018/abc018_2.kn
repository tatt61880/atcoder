func main()
	var s: []char :: cui@input()
	var n: int :: cui@inputInt()
	for(1, n)
		var l: int :: cui@inputInt()
		var r: int :: cui@inputInt()
		var sl: []char :: s.sub(0, l - 1)
		var sm: []char :: s.sub(l - 1, r - l + 1)
		var sr: []char :: s.sub(r, -1)
		do sm.reverse()
		do s :: sl ~ sm ~ sr
	end for
	do cui@print("\{s}\n")
end func
