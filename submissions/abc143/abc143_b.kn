func main()
	var n: int :: cui@inputInt()
	var d: []int :: #[n]int
	for i(0, n - 1)
		do d[i] :: cui@inputInt()
	end for
	
	var ans: int :: 0
	
	for i(0, n - 1)
		var x: int :: d[i]
		for j(i + 1, n - 1)
			var y: int :: d[j]
			do ans :+ x * y
		end for
	end for
	
	do cui@print("\{ans}\n")
end func
