func main()
	var n: int :: cui@inputInt()
	var a: []int :: #[n]int
	for i(0, n - 1)
		do a[i] :: cui@inputInt()
	end for
	
	var q: int :: cui@inputInt()
	for(1, q)
		if(cui@inputChar() = '1')
			var k: int :: cui@inputInt()
			var x: int :: cui@inputInt()
			do a[k - 1] :: x
		else
			var k: int :: cui@inputInt()
			do cui@print("\{a[k - 1]}\n")
		end if
	end for
end func
