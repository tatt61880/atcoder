func main()
	var n: int :: cui@inputInt()
	var a: []int :: #[n]int
	for i(0, n - 1)
		do a[i] :: cui@inputInt()
	end for
	
	var ans: int :: 0
	for m(1, n)
		for d(1, a[m - 1])
			var s: []char :: "\{m}\{d}"
			do s.sort()
			var t: []char :: ##s
			do t.reverse()
			if(s = t)
				do ans :+ 1
			end if
		end for
	end for
	do cui@print("\{ans}\n")
end func
