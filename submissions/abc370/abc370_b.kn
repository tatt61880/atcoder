func main()
 var n:int::cui@inputInt()
 var a:[][]int::#[n][]int
 for i(0,n-1)
  do a[i]::#[i+1]int
  for j(0,i)
   do a[i][j]::cui@inputInt()-1
  end for
 end for
 var ans:int
 for i(0,n-1)
  if(ans>i)
   do ans::a[ans][i]
  else
   do ans::a[i][ans]
  end if
 end for
 do ans:+1
 do cui@print("\{ans}\n")
end func