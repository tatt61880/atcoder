func main()
	var n: int :: cui@inputInt()
	
	var b: []bool :: #[n]bool
	
	for i(0, n - 1)
		if(!b[i])
			do b[cui@inputInt() - 1] :: true
		else
			do cui@inputInt()
		end if
	end for
	
	var cnt: int :: 0
	
	for i(0, n - 1)
		if(!b[i])
			do cnt :+ 1
		end if
	end for
	
	var ans: []int :: #[cnt]int
	var idx: int :: 0
	
	for i(0, n - 1)
		if(!b[i])
			do ans[idx] :: i + 1
			do idx :+ 1
		end if
	end for
	
	do cui@print("\{^ans}\n")
	do cui@print("\{ans.join(" ")}\n")
end func
