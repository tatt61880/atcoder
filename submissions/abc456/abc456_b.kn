func main()
	var a: [][]int :: #[3, 6]int
	for i(0, 2)
		for j(0, 5)
			do a[i][j] :: cui@inputInt()
		end for
	end for
	
	var ans: float :: 0.0
	
	for i(0, 5)
		for j(0, 5)
			for k(0, 5)
				var b: []int :: [a[0][i], a[1][j], a[2][k]]
				do b.sort()
				if(b[0] = 4 & b[1] = 5 & b[2] = 6)
					do ans :+ 1.0
				end if
			end for
		end for
	end for
	
	do ans :/ 216.0
	do cui@print("\{ans}\n")
end func
