func main()
	var s: []char :: cui@input()
	var p: int :: getIdx('A', s)
	
	var ans: int :: 0
	for idx(0, 25)
		var c: char :: 'A'.offset(idx)
		var np: int :: getIdx(c, s)
		do ans :+ (p - np).abs()
		do p :: np
	end for
	do cui@print("\{ans}\n")
	
	func getIdx(c: char, s: []char): int
		for i(0, ^s - 1)
			if(s[i] = c)
				ret i
			end if
		end for
	end func
end func
