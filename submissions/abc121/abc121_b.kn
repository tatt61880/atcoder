func main()
	var n: int :: cui@inputInt()
	var m: int :: cui@inputInt()
	var c: int :: cui@inputInt()
	
	var b: []int :: #[m]int
	for i(0, m - 1)
		do b[i] :: cui@inputInt()
	end for
	
	var ans: int :: 0
	
	for(1, n)
		var v: int :: c
		for i(0, m - 1)
			var a: int :: cui@inputInt()
			do v :+ a * b[i]
		end for
		
		do ans :+ v > 0 ?(1, 0)
	end for
	
	do cui@print("\{ans}\n")
end func
