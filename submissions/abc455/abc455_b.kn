func main()
	var h: int :: cui@inputInt()
	var w: int :: cui@inputInt()
	var s: [][]char :: #[h][]char
	for i(0, h - 1)
		do s[i] :: cui@input()
	end for
	
	var ans: int :: 0
	
	for y1(0, h - 1)
		for x1(0, w - 1)
			for y2(y1, h - 1)
				for x2(x1, w - 1)
					for y(y1, y2)
						for x(x1, x2)
							if(s[y][x] <> s[y1 + y2 - y][x1 + x2 - x])
								skip x2
							end if
						end for
					end for
					do ans :+ 1
				end for
			end for
		end for
	end for
	
	do cui@print("\{ans}\n")
end func
