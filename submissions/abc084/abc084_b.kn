func main()
	var a: int :: cui@inputInt()
	var b: int :: cui@inputInt()
	var s: []char :: cui@inputStr()
	var ans: bool :: ^s = a + b + 1
	for i(0, ^s - 1)
		if(i = a)
			if(s[i] <> '-')
				do ans :: false
			end if
		else
			if(s[i] = '-')
				do ans :: false
			end if
		end if
	end for
	do cui@print((ans ?("Yes", "No")) ~ "\n")
end func