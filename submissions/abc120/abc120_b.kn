func main()
	var a: int :: cui@inputInt()
	var b: int :: cui@inputInt()
	var k: int :: cui@inputInt()
	
	var cnt: int :: 0
	
	for i(lib@min(a, b), 1, -1)
		if(a % i = 0 & b % i = 0)
			do cnt :+ 1
			
			if(cnt = k)
				var ans: int :: i
				do cui@print("\{ans}\n")
				ret
			end if
		end if
	end for
end func
