func main()
	var n: int :: cui@inputInt()
	var t: int :: cui@inputInt()
	var p: int :: cui@inputInt()
	var l: []int :: #[n]int
	for i(0, n - 1)
		do l[i] :: cui@inputInt()
	end for
	
	for x(0, 100)
		var cnt: int :: 0
		for i(0, n - 1)
			if(l[i] + x >= t)
				do cnt :+ 1
			end if
		end for
		if(cnt >= p)
			var ans: int :: x
			do cui@print("\{ans}\n")
			ret
		end if
	end for
end func
