func main()
	var n: int :: cui@inputInt()
	var m: int :: cui@inputInt()
	
	var selected: []bool :: #[m + 1]bool
	
	for loop(1, n)
		var l: int :: cui@inputInt()
		var x: []int :: #[l]int
		for i(0, l - 1)
			do x[i] :: cui@inputInt()
		end for
		
		for i(0, l - 1)
			if(!selected[x[i]])
				do selected[x[i]] :: true
				do cui@print("\{x[i]}\n")
				skip loop
			end if
		end for
		
		do cui@print("0\n")
	end for
end func