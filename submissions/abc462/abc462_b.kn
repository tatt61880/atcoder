func main()
	var n: int :: cui@inputInt()
	
	var ans: [][]int :: #[n][]int
	for i(0, n - 1)
		do ans[i] :: #[0]int
	end for
	for i(0, n - 1)
		var k: int :: cui@inputInt()
		for(1, k)
			var a: int :: cui@inputInt()
			do ans[a - 1] :~ [i + 1]
		end for
	end for
	
	for i(0, n - 1)
		do cui@print("\{^ans[i]} \{ans[i].join(" ")}\n")
	end for
end func
