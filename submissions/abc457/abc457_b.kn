func main()
	var n: int :: cui@inputInt()
	var a: [][]int :: #[n][]int
	for i(0, n - 1)
		var l: int :: cui@inputInt()
		do a[i] :: #[l]int
		for j(0, l - 1)
			do a[i][j] :: cui@inputInt()
		end for
	end for
	var x: int :: cui@inputInt()
	var y: int :: cui@inputInt()
	
	var ans: int :: a[x - 1][y - 1]
	do cui@print("\{ans}\n")
end func
