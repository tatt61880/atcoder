func solveA(h1: int, h2: int)
	var ans: int :: h1 - h2
	do cui@print("\{ans}\n")
end func

func solveB(m: int)
	var vv: int :: 0
	if(m < 100)
		do vv :: 0
	elif(m <= 5000)
		do vv :: m / 100
	elif(m <= 30000)
		do vv :: 50 + m / 1000
	elif(m <= 70000)
		do vv :: (m / 1000 - 30) / 5 + 80
	else
		do vv :: 89
	end if
	do cui@print("\{vv.toStrFmt("02d")}\n")
end func

func solveC(deg: int, dis: int)
	var dir: [][]char :: ["N", "NNE", "NE", "ENE", "E", "ESE", "SE", "SSE", "S", "SSW", "SW", "WSW", "W", "WNW", "NW", "NNW"]
	
	var di: int :: 0
	for i(0, 15)
		if(1125 + 2250 * (di - 1) <= deg * 10 & deg * 10 < 3375 + 2250 * (di - 1))
			break i
		end if
		do di :+ 1
	end for
	
	var ws: []int :: [25, 155, 335, 545, 795, 1075, 1385, 1715, 2075, 2445, 2845, 3265]
	
	var w: int :: 0
	for i(0, 11)
		if(dis * 10 < ws[w] * 6)
			break i
		end if
		do w :+ 1
	end for
	
	do cui@print("\{w <> 0 ?(dir[di % 16], "C")} \{w}\n")
end func

func solveD(n: int, se: [][]char)
	var imos: []int :: #[290]int
	for i(0, n - 1)
		var ss: [][]char :: se[i].split("-")
		var s: int :: timeStrToInt(ss[0])
		var e: int :: timeStrToInt(ss[1])
		
		do imos[s / 5 + 1] :+ 1
		do imos[(e - 1) / 5 + 2] :- 1
	end for
	
	var cnt: int :: 0
	var exists: []bool :: #[290]bool
	
	for i(1, 288)
		do cnt :+ imos[i]
		if(cnt <> 0)
			do exists[i] :: true
		end if
	end for
	
	for i(0, 288)
		if(!exists[i] & exists[i + 1])
			do cui@print("\{timeStr(i * 5)}")
		end if
		if(exists[i] & !exists[i + 1])
			do cui@print("-\{timeStr(i * 5)}\n")
		end if
	end for
	
	func timeStrToInt(x: []char): int
		var h: int :: x.sub(0, 2).toInt(&)
		var m: int :: x.sub(2, 2).toInt(&)
		ret h * 60 + m
	end func
	
	func timeStr(x: int): []char
		var h: int :: x / 60
		var m: int :: x % 60
		ret "\{h.toStrFmt("02d")}\{m.toStrFmt("02d")}"
	end func
end func

func containsHyphen(s: []char): bool
	for i(0, ^s - 1)
		if(s[i] = '-')
			ret true
		end if
	end for
	ret false
end func

func main()
	do cui@delimiter("")
	var input: []char :: cui@inputStr()
	var lines: [][]char :: input.split("\n")
	
	if(^lines >= 1 & lines[^lines - 1] = "")
		do lines :: lines.sub(0, ^lines - 1)
	end if
	
	var first: [][]char :: lines[0].split(" ")
	
	if(^first = 2)
		; C: Deg Dis
		var deg: int :: first[0].toInt(&)
		var dis: int :: first[1].toInt(&)
		
		do @solveC(deg, dis)
		
	elif(^lines = 1)
		; B: m
		var m: int :: lines[0].toInt(&)
		
		do @solveB(m)
		
	elif(@containsHyphen(lines[1]))
		; D: N, S_i-E_i
		var n: int :: lines[0].toInt(&)
		var se: [][]char :: #[n][]char
		
		for i(0, n - 1)
			do se[i] :: lines[i + 1]
		end for
		
		do @solveD(n, se)
		
	else
		; A: H_1, H_2
		var h1: int :: lines[0].toInt(&)
		var h2: int :: lines[1].toInt(&)
		
		do @solveA(h1, h2)
	end if
end func
