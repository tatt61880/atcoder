func main()
	var n: int :: cui@inputInt()
	var m: int :: cui@inputInt()
	
	var a: []int :: #[n]int
	var sum: int
	for i(0, n - 1)
		do a[i] :: cui@inputInt()
		do sum :+ a[i]
	end for
	
	var cnt: int :: 0
	for i(0, n - 1)
		do cnt :+ a[i] * 4 * m >= sum ?(1, 0)
	end for
	
	var ans: bool :: cnt >= m
	do cui@print((ans ?("Yes", "No")) ~ "\n")
end func
