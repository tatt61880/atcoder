func main()
	var n: int :: cui@inputInt()
	
	var dic: dict<int, bool> :: #dict<int, bool>
	do dic.add(cui@inputInt(), true)
	do dic.add(cui@inputInt(), true)
	
	var k: int :: cui@inputInt()
	
	for(1, k)
		do dic.add(cui@inputInt(), true)
	end for
	
	var ans: bool :: ^dic = k + 2
	do cui@print((ans ?("YES", "NO")) ~ "\n")
end func
