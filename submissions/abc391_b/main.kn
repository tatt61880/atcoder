func main()
 var n: int :: cui@inputInt()
 var m: int :: cui@inputInt()
 var s: [][]char :: #[n][]char
 for h(0, n - 1)
  do s[h] :: cui@input()
 end for
 var t: [][]char :: #[m][]char
 for h(0, m - 1)
  do t[h] :: cui@input()
 end for
 for r(0, n - m)
  for c(0, n -m)
   for y(0, m - 1)
    for x(0, m - 1)
     if(t[y][x] <> s[r + y][c + x])
      skip c
     end if
    end for
   end for
   do cui@print("\{r + 1} \{c + 1}\n")
  end for
 end for
end func