func main()
	var n: int :: cui@inputInt()
	var s: []char :: cui@input()
	
	var ans: int :: 0
	for i(0, ^s - 1)
		do ans :: lib@max(ans, f(s, i))
	end for
	
	do cui@print("\{ans}\n")
	
	func f(s: []char, a: int): int
		var res: int :: 0
		
		for i(0, a)
			var c: char :: s[i]
			for j(0, i - 1)
				if(s[j] = c)
					skip i
				end if
			end for
			
			for j(a + 1, ^s - 1)
				if(s[j] = c)
					do res :+ 1
					skip i
				end if
			end for
		end for
		
		ret res
	end func
end func
