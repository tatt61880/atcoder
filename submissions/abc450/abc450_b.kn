func main()
	var n: int :: cui@inputInt()
	var C: [][]int :: #[n][]int
	for i(1, n - 1)
		do C[i] :: #[n + 1]int
		for j(i + 1, n)
			do C[i][j] :: cui@inputInt()
		end for
	end for
	
	var ans: bool :: false
	for a(1, n)
		for b(a + 1, n)
			for c(b + 1, n)
				if(C[a][b] + C[b][c] < C[a][c])
					do ans :: true
				end if
			end for
		end for
	end for
	do cui@print((ans ?("Yes", "No")) ~ "\n")
end func
