func main()
 var n:int::cui@inputInt()
 var ac:int
 var wa:int
 var tle:int
 var re:int
 for(1,n)
  switch(cui@input())
   case "AC"
    do ac:+1
   case "WA"
    do wa:+1
   case "TLE"
    do tle:+1
   case "RE"
    do re:+1
  end switch
 end for
 do cui@print("AC x \{ac}\n")
 do cui@print("WA x \{wa}\n")
 do cui@print("TLE x \{tle}\n")
 do cui@print("RE x \{re}\n")
end func