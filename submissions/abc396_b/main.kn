func main()
	var q: int :: cui@inputInt()
	var st: stack<int> :: #stack<int>
	for(1, q)
		var t: int :: cui@inputInt()
		if(t = 1)
			var x: int :: cui@inputInt()
			do st.add(x)
		else
			var ans: int :: 0
			if(^st <> 0)
				do ans :: st.get()
			end if
			do cui@print("\{ans}\n")
		end if
	end for
end func
