func main()
	var n: int :: cui@inputInt()
	var x: int :: cui@inputInt()
	
	var a: []int :: #[n - 1]int
	for i(0, n - 2)
		do a[i] :: cui@inputInt()
	end for
	
	do a.sort()
	
	var mn: int :: a[0]
	var md: int
	var mx: int :: a[n - 2]
	
	for i(1, n - 3)
		do md :+ a[i]
	end for
	
	var ans: int :: 0
	
	if(mn + md >= x)
		do ans :: 0
	elif(md + mx < x)
		do ans :: -1
	else
		do ans :: x - md
	end if
	
	do cui@print("\{ans}\n")
end func
