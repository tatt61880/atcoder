func main()
	var n: int :: cui@inputInt()
	var q: int :: cui@inputInt()
	
	var ans: []int :: #[n]int
	for(1, q)
		var l: int :: cui@inputInt() - 1
		var r: int :: cui@inputInt() - 1
		var t: int :: cui@inputInt()
		for i(l, r)
			do ans[i] :: t
		end for
	end for
	do cui@print("\{ans.join("\n")}\n")
end func
