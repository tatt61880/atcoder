func main()
	var n: int :: cui@inputInt()
	var a: []int :: #[n]int
	var sum: int :: 0
	for i(0, n - 1)
		do a[i] :: cui@inputInt()
		do sum :+ a[i]
	end for
	
	if(sum % n <> 0)
		do cui@print("-1\n")
		ret
	end if
	
	var target: int :: sum / n
	
	var ans: int :: 0
	do sum :: 0
	for i(0, n - 1)
		do sum :+ a[i]
		if(sum <> target * (i + 1))
			do ans :+ 1
		end if
	end for
	
	do cui@print("\{ans}\n")
end func
