func main()
	var a: int :: cui@inputInt()
	var b: int :: cui@inputInt()
	var c: int :: cui@inputInt()
	var d: int :: cui@inputInt()
	
	while loop(true)
		do c :- b
		if(c <= 0)
			break loop
		end if
		
		do a :- d
		if(a <= 0)
			break loop
		end if
	end while
	
	var ans: bool :: a > 0
	do cui@print((ans ?("Yes", "No")) ~ "\n")
end func
