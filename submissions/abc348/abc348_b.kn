func main()
	var n: int :: cui@inputInt()
	var x: []int :: #[n]int
	var y: []int :: #[n]int
	for i(0, n - 1)
		do x[i] :: cui@inputInt()
		do y[i] :: cui@inputInt()
	end for
	
	for i(0, n - 1)
		var max: int
		var ans: int
		for j(0, n - 1)
			var d: int :: (x[i] - x[j]) ^ 2 + (y[i] - y[j]) ^ 2
			if(d > max)
				do max :: d
				do ans :: j + 1
			end if
		end for
		do cui@print("\{ans}\n")
	end for
end func
