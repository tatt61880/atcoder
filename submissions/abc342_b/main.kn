func main()
	var n: int :: cui@inputInt()
	var pPos: []int :: #[n + 1]int
	for i(1, n)
		do pPos[cui@inputInt()] :: i
	end for
	
	var q: int :: cui@inputInt()
	for i(1, q)
		var a: int :: cui@inputInt()
		var b: int :: cui@inputInt()
		if(pPos[a] < pPos[b])
			do cui@print("\{a}\n")
		else
			do cui@print("\{b}\n")
		end if
	end for
end func
