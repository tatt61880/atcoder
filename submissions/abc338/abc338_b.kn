func main()
	var s: []char :: cui@inputStr()
	
	var cnts: []int :: #[26]int
	for i(0, ^s - 1)
		do cnts[s[i] $ int - 'a' $ int] :+ 1
	end for
	
	var max: int :: cnts.max()
	var idx: int :: 0
	for i(0, 25)
		if(cnts[i] = max)
			do idx :: i
			break i
		end if
	end for
	
	var ans: char :: 'a'.offset(idx)
	do cui@print("\{ans}\n")
end func
