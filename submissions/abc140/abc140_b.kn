func main()
	var n: int :: cui@inputInt()
	var a: []int :: #[n]int
	var b: []int :: #[n]int
	var c: []int :: #[n - 1]int
	for i(0, n - 1)
		do a[i] :: cui@inputInt()
	end for
	for i(0, n - 1)
		do b[i] :: cui@inputInt()
	end for
	for i(0, n - 2)
		do c[i] :: cui@inputInt()
	end for
	
	var ans: int :: 0
	for i(0, n - 1)
		do ans :+ b[i]
		if(i <> n - 1 & a[i] + 1 = a[i + 1])
			do ans :+ c[a[i] - 1]
		end if
	end for
	
	do cui@print("\{ans}\n")
end func
