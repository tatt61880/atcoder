func main()
	var n: int :: cui@inputInt()
	var m: int :: cui@inputInt()
	var a: []int :: #[m]int
	for i(0, m - 1)
		do a[i] :: cui@inputInt()
	end for
	
	var ans: []int :: #[0]int
	for i(1, n)
		for j(0, m - 1)
			if(a[j] = i)
				skip i
			end if
		end for
		do ans :~ [i]
	end for
	
	do cui@print("\{^ans}\n")
	do cui@print("\{ans.join(" ")}\n")
end func
