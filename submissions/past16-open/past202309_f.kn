func main()
	var s: []char :: cui@input()
	var ss: [][]char :: s.split("*")
	var ans: int :: 1
	for i(0, ^ss - 1)
		do ans :* f(ss[i])
		do ans :% 998244353
	end for
	do cui@print("\{ans}\n")
	
	func f(s: []char): int
		var res: int :: 0
		for i(0, ^s - 1)
			do res :* 10
			do res :+ s[i] $ int - '0' $ int
			do res :% 998244353
		end for
		ret res
	end func
end func