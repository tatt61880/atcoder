func main()
	var s: []char :: "wbwbwwbwbwbw".repeat(20)
	
	var w: int :: cui@inputInt()
	var b: int :: cui@inputInt()
	
	var ans: bool :: false
	for i(0, 11)
		var cntW: int :: 0
		var cntB: int :: 0
		for j(0, w + b - 1)
			if(s[i + j] = 'w')
				do cntW :+ 1
			else
				do cntB :+ 1
			end if
		end for
		if(cntW = w & cntB = b)
			do ans :: true
			break i
		end if
	end for
	do cui@print((ans ?("Yes", "No")) ~ "\n")
end func
