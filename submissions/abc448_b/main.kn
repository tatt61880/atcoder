func main()
 var n:int::cui@inputInt()
 var m:int::cui@inputInt()
 var c:[]int::#[m+1]int
 for i(1,m)
  do c[i]::cui@inputInt()
 end for
 
 var d:[]int::#[m+1]int
 for i(1,n)
  var a:int::cui@inputInt()
  var b:int::cui@inputInt()
  do d[a]:+b
 end for
 var ans:int
 for i(1,m)
  do ans:+lib@min(c[i],d[i])
 end for
 do cui@print("\{ans}\n")
end func