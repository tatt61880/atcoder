func main()
	var n: int :: cui@inputInt()
	var a: []int :: #[n]int
	for i(0, n - 1)
		do a[i] :: cui@inputInt()
	end for
	var b: []int :: #[n]int
	for i(0, n - 1)
		do b[i] :: cui@inputInt()
	end for
	
	var ans: bool :: true
	
	for i(0, n - 1)
		if(b[a[i] - 1] <> i + 1)
			do ans :: false
		end if
		if(a[b[i] - 1] <> i + 1)
			do ans :: false
		end if
	end for
	
	do cui@print((ans ?("Yes", "No")) ~ "\n")
end func
