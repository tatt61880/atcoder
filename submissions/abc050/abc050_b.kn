func main()
	var n: int :: cui@inputInt()
	var t: []int :: #[n]int
	
	var ans: int :: 0
	for i(0, n - 1)
		do t[i] :: cui@inputInt()
		do ans :+ t[i]
	end for
	
	var m: int :: cui@inputInt()
	for(1, m)
		var p: int :: cui@inputInt() - 1
		var x: int :: cui@inputInt()
		do ans :+ x - t[p]
		do cui@print("\{ans}\n")
		do ans :- x - t[p]
	end for
end func
